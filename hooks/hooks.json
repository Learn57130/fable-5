{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/AGENTS.md\"; exit 0",
            "commandWindows": "Get-Content \"$env:CLAUDE_PLUGIN_ROOT\\AGENTS.md\"",
            "timeout": 5,
            "statusMessage": "Loading fable-5 loop..."
          }
        ]
      }
    ]
  }
}
